# ===============================
# إعدادات البوت — Discord Ticket Bot v5
# تم التطوير بواسطة كيرو
# ===============================

# توكن البوت من Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Client ID الخاص بالبوت
DISCORD_CLIENT_ID=your_client_id_here

# معرف صاحب السيرفر (Discord User ID)
OWNER_ID=your_user_id_here

# رابط قاعدة بيانات PostgreSQL
BOT_DATABASE_URL=postgresql://user:password@localhost:5432/ticket_bot

# ===============================
# إعدادات اختيارية
# ===============================

# مفتاح OpenAI (اختياري — لنظام AI التلقائي)
# OPENAI_API_KEY=sk-...

# رابط مخصص لـ OpenAI API (اختياري)
# OPENAI_BASE_URL=https://api.openai.com/v1
